{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "mini-player-window",
  "description": "Minimal capabilities for the mini-player window — events and window control only",
  "windows": ["mini-player"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen"
  ]
}
